# === Application ===
APP_NAME=ClipoAI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# === Backend ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80

# === Database (PostgreSQL) ===
POSTGRES_USER=clipoai
POSTGRES_PASSWORD=clipoai_dev_password
POSTGRES_DB=clipoai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://clipoai:clipoai_dev_password@postgres:5432/clipoai

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# === MinIO (S3-compatible storage) ===
MINIO_ROOT_USER=clipoai
MINIO_ROOT_PASSWORD=clipoai_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=clipoai-videos
MINIO_USE_SSL=false

# === Qdrant (Vector DB) ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# === JWT Authentication ===
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === YouTube ===
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# === AI / LLM (Phase 2+) ===
GEMINI_API_KEY=your-gemini-api-key

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# === Grafana ===
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
